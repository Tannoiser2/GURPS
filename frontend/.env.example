# URL del backend Railway. Copiare questo file in .env.local per sviluppo locale
# e impostare VITE_API_URL nelle impostazioni di Vercel per il deploy di produzione.
#
# Su Vercel: Project Settings → Environment Variables → aggiungi:
#   VITE_API_URL = https://<nome-tuo-progetto>.railway.app
#
VITE_API_URL=https://your-project.railway.app
