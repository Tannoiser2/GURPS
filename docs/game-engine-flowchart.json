    },
    {
      "from": "image_endpoints",
      "to": "claude_service",
      "label": "generate_*_image",
      "kind": "call"
    },
    {
      "from": "state_endpoint",
      "to": "game_state",
      "label": "legge snapshot",
      "kind": "read_state"
    },
    {
      "from": "fastapi_app",
      "to": "react_app",
      "label": "JSON risposta",
      "kind": "http_response"
    },
    {
      "from": "react_app",
      "to": "player",
      "label": "render UI aggiornata",
      "kind": "render"
    }
  ],
  "primary_flows": [
    {
      "id": "new_ai_adventure",
      "label": "Nuova avventura AI",
      "steps": [
        "player",
        "react_app",
        "adventure_create_endpoint",
        "claude_service",
        "adventure_compiler",
        "runtime_shape_builder",
        "runtime_models",
        "react_app"
      ]
    },
    {
      "id": "pdf_import_adventure",
      "label": "Import avventura da PDF",
      "steps": [
        "player",
        "react_app",
        "adventure_create_endpoint",
        "pdf_structure_extractor",
        "adventure_compiler",
        "runtime_shape_builder",
        "runtime_models",
        "runtime_store",
        "react_app"
      ]
    },
    {
      "id": "master_turn",
      "label": "Turno narrativo principale",
      "steps": [
        "player",
        "react_app",
        "master_turn_endpoint",
        "engine",
        "action_intent",
        "data_rules",
        "game_state",
        "claude_service",
        "adventure_runtime",
        "engine",
        "world_systems",
        "game_state",
        "react_app",
        "player"
      ]
    },
    {
      "id": "combat_exchange",
      "label": "Scambio di combattimento",
      "steps": [
        "player",
        "react_app",
        "combat_endpoints",
        "engine",
        "combat_rules",
        "data_rules",
        "models",
        "game_state",
        "claude_service",
        "react_app",
        "player"
      ]
    },
    {
      "id": "state_refresh",
      "label": "Refresh stato UI",
      "steps": [
        "react_app",
        "state_endpoint",
        "game_state",
        "react_app"
      ]
    }
  ],
  "decision_points": [
    {
      "id": "source_mode_decision",
      "label": "Sorgente avventura",
      "question": "Avventura generata da prompt AI o importata da PDF?",
      "branches": [
        {
          "condition": "prompt/testo libero",
          "next": "claude_service"
        },
        {
          "condition": "PDF",
          "next": "pdf_structure_extractor"
        }
      ]
    },
    {
      "id": "turn_resolution_decision",
      "label": "Esito azione",
      "question": "Il tiro GURPS produce successo, fallimento o critico?",
      "branches": [
        {
          "condition": "successo o critico",
          "next": "claude_service"
        },
        {
          "condition": "fallimento",
          "next": "claude_service"
        }
      ],
      "note": "La narrativa riceve il risultato gia deciso dal motore; non decide autonomamente l'esito meccanico."
    },
    {
      "id": "combat_activation_decision",
      "label": "Attivazione combattimento",
      "question": "state_updates contiene activate_combat o combat_scene?",
      "branches": [
        {
          "condition": "si",
          "next": "combat_endpoints"
        },
        {
          "condition": "no",
          "next": "react_app"
        }
      ]
    },
    {
      "id": "attack_defense_decision",
      "label": "Difesa attiva",
      "question": "L'attacco colpisce e permette difesa?",
      "branches": [
        {
          "condition": "si",
          "next": "POST /game/combat/defend"
        },
        {
          "condition": "no",
          "next": "applica danno o miss"
        }
      ]
    },
    {
      "id": "finale_decision",
      "label": "Finale storia",
      "question": "state_updates o runtime indicano storia conclusa?",
      "branches": [
        {
          "condition": "si",
          "next": "valutazione finale e vittorie personali"
        },
        {
          "condition": "no",
          "next": "prossimo turno"
        }
      ]
    }
  ],
  "contracts": [
    {
      "id": "frontend_backend_contract",
      "label": "Contratto React/FastAPI",
      "format": "JSON HTTP",
      "important_payloads": [
        "adventure bible",
        "master response",
        "state_updates",
        "combat_scene",
        "GameState snapshot"
      ]
    },
    {
      "id": "roll_before_ai_contract",
      "label": "Tiro prima della narrativa",
      "rule": "Il motore esegue roll_for_player_action prima di chiamare master_turn_with_bible; la AI deve raccontare l'esito ricevuto."
    },
    {
      "id": "shared_game_state_contract",
      "label": "Stato condiviso",
      "rule": "Narrativa, mappa, PG e combattimento aggiornano lo stesso GameState globale in backend/App/main.py."
    },
    {
      "id": "runtime_preservation_contract",
      "label": "Preservazione runtime",
      "rule": "Le avventure importate o compilate mantengono riferimenti a luoghi, indizi, attori e clock tramite AdventureDefinition/AdventureRuntimeState."
    }
  ],
  "related_docs": [
    "docs/gurps-code-flowchart.md",
    "docs/scene-resolution-flowchart.md",
    "docs/tactical-combat-flowchart.md",
    "docs/adventure-compiler-flowchart.md"
  ]
}
