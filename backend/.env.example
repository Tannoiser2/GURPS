# Copia questo file come .env e inserisci le tue chiavi

# Provider Claude + Gemini
ANTHROPIC_API_KEY=your_anthropic_key_here
# Chiave Google AI Studio per la generazione immagini (https://aistudio.google.com/apikey)
GOOGLE_AI_STUDIO_KEY=your_google_ai_studio_key_here

# Provider ChatGPT (OpenAI) — alternativo a Claude+Gemini
OPENAI_API_KEY=your_openai_key_here
